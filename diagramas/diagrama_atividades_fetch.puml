@startuml diagrama_atividades_fetch

skinparam backgroundColor white
skinparam activity {
    BackgroundColor #F8F8F8
    BorderColor #333333
    ArrowColor #444444
    DiamondBackgroundColor #FFFDE7
    DiamondBorderColor #888800
}
skinparam note {
    BackgroundColor #EEF4FF
    BorderColor #5566AA
}

title GithubMiner.fetch_data(pages)\nAlgoritmo de MineraĂ§ĂŁo de Dados

start

:Inicializar variĂˇveis\n(users_set, edges_g1/g2/g3, edges_integrated);

:Definir page = 1;

while (page <= pages?) is (sim)

    :GET /repos/{owner}/{repo}/issues\n?state=all&per_page=100&page={page};

    if (resposta HTTP 200?) then (nĂŁo)
        :print aviso de erro\nretornar lista vazia;
    else (sim)
        :iterar sobre lista de items;

        while (hĂˇ prĂłximo item?) is (sim)

            :extrair author\nadicionar author a users_set\ndetectar is_PR (chave "pull_request");

            :GET {item.comments_url};

            while (hĂˇ prĂłximo comentĂˇrio?) is (sim)
                :commenter = autor do comentĂˇrio;
                if (commenter != author?) then (sim)
                    :edges_g1[(commenterâ†’author)] += 1;
                    :edges_integrated[(commenterâ†’author)] += 2;
                else (nĂŁo)
                    :ignorar (auto-comentĂˇrio);
                endif
            endwhile (nĂŁo)

            if (item Ă© PR?) then (nĂŁo â€” Ă© Issue)

                if (state == "closed" AND\nclosed_by != null?) then (sim)
                    :closer = closed_by.login\nedges_g2[(closerâ†’author)] += 1;
                else (nĂŁo)
                    :nenhuma aresta G2;
                endif

                :edges_integrated[(authorâ†’commenter)] += 3\n(autor responde a comentadores);

            else (sim â€” Ă© PR)

                :GET /repos/{owner}/{repo}/pulls/{number}/reviews;

                while (hĂˇ prĂłximo review?) is (sim)
                    :reviewer = review.user.login;
                    if (reviewer != author?) then (sim)
                        :edges_g3[(reviewerâ†’author)] += 1;
                        :edges_integrated[(reviewerâ†’author)] += 4;
                    else (nĂŁo)
                    endif
                endwhile (nĂŁo)

                :GET /repos/{owner}/{repo}/pulls/{number};

                if (merged == true AND\nmerged_by != null?) then (sim)
                    :merger = merged_by.login\nedges_g3[(mergerâ†’author)] += 1;
                    :edges_integrated[(mergerâ†’author)] += 5;
                else (nĂŁo)
                    :PR nĂŁo foi mergeado;
                endif

            endif

        endwhile (nĂŁo)
    endif

    :page += 1;

endwhile (nĂŁo)

note right
  Pesos acumulados por tipo:
  * G1: comentĂˇrios
  * G2: fechamento de issues
  * G3: reviews + merges
  * Integrated: tudo combinado
    (2, 3, 4 ou 5 por interaĂ§ĂŁo)
end note

:MineraĂ§ĂŁo concluĂ­da\nDados prontos para build_graphs();

stop

@enduml
